{
  "name": "@jtalk22/slack-mcp",
  "mcpName": "io.github.jtalk22/slack-mcp-server",
  "version": "2.0.0",
  "description": "Session-based Slack access for Claude - DMs, channels, search, and threads. Local-first with your existing Slack session.",
  "type": "module",
  "main": "src/server.js",
  "bin": {
    "slack-mcp": "src/cli.js",
    "slack-mcp-server": "src/server.js",
    "slack-mcp-http": "src/server-http.js",
    "slack-mcp-web": "src/web-server.js",
    "slack-mcp-setup": "scripts/setup-wizard.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "http": "node src/server-http.js",
    "web": "node src/web-server.js",
    "setup": "node scripts/setup-wizard.js --setup",
    "hooks:setup": "bash scripts/setup-git-hooks.sh",
    "verify:owner-attribution": "bash scripts/check-owner-attribution.sh",
    "tokens:status": "node scripts/token-cli.js status",
    "tokens:refresh": "node scripts/token-cli.js refresh",
    "tokens:auto": "node scripts/token-cli.js auto",
    "tokens:clear": "node scripts/token-cli.js clear",
    "screenshot": "node scripts/capture-screenshots.js",
    "record-demo": "node scripts/record-demo.js",
    "metrics:release-health": "node scripts/collect-release-health.js",
    "metrics:release-health:delta": "node scripts/build-release-health-delta.js",
    "verify:version-parity": "node scripts/check-version-parity.js"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "slack",
    "slack-api",
    "slack-mcp",
    "slack-integration",
    "claude",
    "claude-desktop",
    "claude-code",
    "cursor",
    "llm",
    "ai",
    "ai-assistant",
    "automation",
    "workflow-automation",
    "developer-tools",
    "cli",
    "productivity",
    "messaging",
    "message-search",
    "direct-messages",
    "channels",
    "workspace",
    "session-based",
    "session-mirroring",
    "slack-dm",
    "slack-threads",
    "workspace-search",
    "mcp-tools",
    "mcp-stdio",
    "mcp-http",
    "open-source"
  ],
  "author": "jtalk22",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jtalk22/slack-mcp-server.git"
  },
  "homepage": "https://jtalk22.github.io/slack-mcp-server/public/demo.html",
  "bugs": {
    "url": "https://github.com/jtalk22/slack-mcp-server/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "express": "^4.18.2"
  },
  "files": [
    "src/",
    "lib/",
    "public/",
    "scripts/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "playwright": "^1.57.0"
  }
}
